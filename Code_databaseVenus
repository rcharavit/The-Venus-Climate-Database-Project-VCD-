import numpy as np
import matplotlib.pyplot as plt


# Read a VCD 2D text file with || separators

def read_vcd_2d(filepath):
    """
    Reads a 2D VCD text file with the format:

    ---- || lat1 lat2 lat3 ...
    lon1 || val1 val2 val3 ...
    lon2 || val1 val2 val3 ...

    Returns
    -------
    latitudes : np.ndarray, shape (nlat,)
    longitudes : np.ndarray, shape (nlon,)
    values : np.ndarray, shape (nlon, nlat)
    """
    with open(filepath, "r", encoding="utf-8-sig") as f:
        lines = f.readlines()

    latitudes = None
    data_rows = []

    for line in lines:
        line = line.strip()

        if not line:
            continue

        # Skip comments
        if line.startswith("#"):
            continue

        # Skip separator lines made only of "-"
        if set(line) == {"-"}:
            continue

        # Latitude line
        if line.startswith("----"):
            if "||" not in line:
                continue
            _, right = line.split("||", 1)
            parts = right.split()
            latitudes = np.array([float(x) for x in parts], dtype=float)
            continue

        # Data lines
        if "||" in line:
            left, right = line.split("||", 1)
            try:
                lon = float(left.strip())
                vals = [float(x) for x in right.split()]
                data_rows.append([lon] + vals)
            except ValueError:
                continue

    if latitudes is None:
        raise ValueError("Latitude line not found.")

    if len(data_rows) == 0:
        raise ValueError("No data rows found.")

    data = np.array(data_rows, dtype=float)
    longitudes = data[:, 0]
    values = data[:, 1:]

    if values.shape[1] != len(latitudes):
        raise ValueError(
            f"Inconsistency: {values.shape[1]} columns for {len(latitudes)} latitudes."
        )

    return latitudes, longitudes, values


# Extract temperature as a function of latitude
# for the longitude closest to lon0

def extract_latitudinal_profile(filepath, lon0=0.0):
    """
    Returns the temperature profile as a function of latitude
    for the longitude closest to lon0.
    """
    lat, lon, values = read_vcd_2d(filepath)

    # Longitude closest to requested lon0
    ilon = np.argmin(np.abs(lon - lon0))
    selected_lon = lon[ilon]

    # Temperature for all latitudes at this longitude
    T_lat = values[ilon, :]

    return lat, T_lat, selected_lon


# Print all temperatures as a function of latitude
# for longitude closest to lon0


def print_all_latitudes(filepath, variable_name="Temperature", unit="K", lon0=0.0):
    """
    Prints the value of the selected variable for all latitudes,
    using the longitude closest to lon0.
    """
    lat, T_lat, selected_lon = extract_latitudinal_profile(filepath, lon0=lon0)

    print(f"\nFile: {filepath}")
    print(f"Selected longitude: {selected_lon:.2f}°\n")

    for la, temp in zip(lat, T_lat):
        print(f"Latitude = {la:8.2f}°   {variable_name} = {temp:8.3f} {unit}")



